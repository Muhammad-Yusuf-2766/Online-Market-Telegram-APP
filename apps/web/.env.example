# Base URL for the Nest API (no trailing slash).
# - Dev: leave unset to use the local API default.
# - Phone/ngrok testing: set to the public HTTPS API/ngrok origin so uploaded
#   /uploads/... product and banner images resolve outside your computer.
# - Prod (Railway / cross-origin): REQUIRED, baked into the bundle via Docker ARG.
#   Set on the web service before build: VITE_API_BASE_URL=https://<api>.up.railway.app
# VITE_API_BASE_URL=https://your-api-ngrok-or-production-domain

# Browser-only dev sign-in (not Telegram): both must be set, then restart Vite.
# VITE_DEV=true
# VITE_DEV_JWT=paste-a-valid-user-jwt-from-the-api
