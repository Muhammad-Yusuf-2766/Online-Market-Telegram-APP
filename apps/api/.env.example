# PostgreSQL — used by Prisma (see docs/DEVOPS.md)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ansor_market?schema=public"

NODE_ENV=development
PORT=3000

# JWT — Telegram mini-app users (after POST /auth/telegram)
JWT_SECRET="change-me-user-jwt"
JWT_EXPIRES_IN=7d

# JWT — admin panel (POST /admin/auth/login)
ADMIN_JWT_SECRET="change-me-admin-jwt"
ADMIN_JWT_EXPIRES_IN=1d

# Telegram Web App — required for validating initData (never expose to browsers)
TELEGRAM_BOT_TOKEN=""
# Reject initData older than this many seconds (default 86400)
TELEGRAM_INIT_DATA_MAX_AGE_SEC=86400
# Public HTTPS URL of the Telegram Mini App (must match BotFather Web App URL). Used in order-status messages: link + “Открыть заказ” button → /orders/<id>
TELEGRAM_WEB_APP_URL=""
# Telegram Mini App deep links: username without @, and BotFather short name
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEB_APP_SHORT_NAME=""

# Kakao Local API — backend-only address search proxy (`GET /addresses/search?q=...`)
KAKAO_REST_API_KEY=""

# MinIO (S3-compatible) — used by POST /admin/storage/presign for product image uploads.
# When running via docker-compose, the bundled minio service auto-creates the bucket and
# grants anonymous read on uploaded objects (so MINIO_PUBLIC_URL is directly viewable).
# Defaults below match the docker-compose minio service.
MINIO_ENDPOINT="http://127.0.0.1"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET=ansor-market
# Public base URL used in presign responses (must be reachable from the browser).
MINIO_PUBLIC_URL="http://127.0.0.1:9000"
MINIO_PRESIGN_EXPIRES_SEC=3600

# Optional public API base URL used in local upload responses.
# If unset, uploaded files are stored as relative /uploads/... paths and browser apps resolve
# them with VITE_API_BASE_URL. For ngrok/production, set this to the public HTTPS API origin.
# API_PUBLIC_URL="https://your-api-ngrok-or-production-domain"

# Comma-separated browser origins for CORS (leave unset to reflect request origin in dev)
# CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Prisma seed (`pnpm --filter api db:seed`) — Super Admin, starter units, categories, and products.
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="changeme"
