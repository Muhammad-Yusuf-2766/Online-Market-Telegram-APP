generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserGender {
  UNSPECIFIED
  MALE
  FEMALE
  OTHER
}

enum ProductFeedbackStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AdminNotificationKind {
  ORDER_CREATED
  ORDER_UPDATED
}

enum UserNotificationKind {
  BROADCAST
  ORDER_STATUS
  SYSTEM
}

enum BroadcastStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

model User {
  id               String     @id @default(cuid())
  telegramId       String     @unique
  telegramUsername String?
  firstName        String?
  lastName         String?
  locale           String     @default("uz")
  phone            String?
  birthDate        DateTime?  @db.Date
  gender           UserGender @default(UNSPECIFIED)
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  addresses         UserAddress[]
  orders            Order[]
  productFeedbacks  ProductFeedback[]
  cart              Cart?
  wishlistItems     Wishlist[]
  broadcastLogs     BroadcastLog[]
  userNotifications UserNotification[]
}

model UserAddress {
  id               String   @id @default(cuid())
  userId           String
  label            String?
  recipientName    String?
  phone            String?
  addressName      String
  roadAddressName  String?
  jibunAddressName String?
  buildingName     String?
  zoneNo           String?
  detailAddress    String
  latitude         Float?
  longitude        Float?
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String?
  isActive     Boolean  @default(true)
  isSuperAdmin Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notificationReads AdminNotificationRead[]
}

model AdminNotification {
  id        String                @id @default(cuid())
  kind      AdminNotificationKind
  orderId   String
  createdAt DateTime              @default(now())

  order Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reads AdminNotificationRead[]

  @@index([createdAt])
  @@index([orderId])
}

model AdminNotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  adminUserId    String
  readAt         DateTime @default(now())

  notification AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  admin        AdminUser         @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([notificationId, adminUserId])
  @@index([adminUserId])
}

model MeasurementUnit {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  symbol       String
  sortOrder    Int      @default(0)
  allowDecimal Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products Product[]
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  parentId  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id                String   @id @default(cuid())
  title             String
  description       String   @default("")
  priceKrw          Int
  oldPriceKrw       Int?
  discountPercent   Int?
  isOnSale          Boolean  @default(false)
  isBestSeller      Boolean  @default(false)
  stockQuantity     Int      @default(0)
  lowStockThreshold Int?
  images            String[] @default([])
  ratingAvg         Float?
  ratingCount       Int      @default(0)
  isActive          Boolean  @default(true)
  categoryId        String
  measurementUnitId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category        Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  measurementUnit MeasurementUnit     @relation(fields: [measurementUnitId], references: [id], onDelete: Restrict)
  orderItems      OrderItem[]
  feedbacks       ProductFeedback[]
  cartItems       CartItem[]
  wishlistItems   Wishlist[]
  inventoryMoves  InventoryMovement[]

  @@index([categoryId])
  @@index([measurementUnitId])
  @@index([isActive, createdAt])
  @@index([isOnSale, isActive])
  @@index([isBestSeller, isActive])
}

model ProductFeedback {
  id        String                @id @default(cuid())
  productId String
  userId    String
  stars     Int
  comment   String                @default("")
  status    ProductFeedbackStatus @default(PENDING)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, status])
  @@index([status, createdAt])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  qty       Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Wishlist {
  id                   String   @id @default(cuid())
  userId               String
  productId            String
  notifyBackInStock    Boolean  @default(true)
  notifyPriceDrop      Boolean  @default(true)
  lastNotifiedPriceKrw Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  status                OrderStatus @default(PENDING)
  subtotalKrw           Int
  deliveryFeeKrw        Int         @default(0)
  totalKrw              Int
  discountKrw           Int         @default(0)
  deliveryPhone         String?
  deliveryFirstName     String?
  deliveryLastName      String?
  addressId             String?
  addressNameSnapshot   String
  roadAddressSnapshot   String?
  jibunAddressSnapshot  String?
  buildingNameSnapshot  String?
  zoneNoSnapshot        String?
  detailAddressSnapshot String
  latitudeSnapshot      Float?
  longitudeSnapshot     Float?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items              OrderItem[]
  inventoryMovements InventoryMovement[]
  adminNotifications AdminNotification[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id                 String  @id @default(cuid())
  orderId            String
  productId          String?
  quantity           Int
  unitPriceKrw       Int
  titleSnapshot      String
  imageSnapshot      String?
  unitNameSnapshot   String?
  unitSymbolSnapshot String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Banner {
  id        String    @id @default(cuid())
  imageUrl  String
  title     String?
  linkUrl   String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model MarketBranding {
  id                       String   @id @default("default")
  marketName               String   @default("Ansor Market")
  marketSlogan             String   @default("Koreadagi halal mahsulotlar")
  marketLogoUrl            String?
  deliveryPriceKrw         Int      @default(0)
  freeDeliveryThresholdKrw Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model UserNotification {
  id        String               @id @default(cuid())
  userId    String
  kind      UserNotificationKind
  title     String
  body      String
  imageUrl  String?
  targetUrl String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Broadcast {
  id         String          @id @default(cuid())
  title      String
  body       String
  imageUrl   String?
  targetUrl  String?
  status     BroadcastStatus @default(DRAFT)
  sentCount  Int             @default(0)
  errorCount Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  logs BroadcastLog[]
}

model BroadcastLog {
  id          String   @id @default(cuid())
  broadcastId String
  userId      String
  status      String
  error       String?
  createdAt   DateTime @default(now())

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([broadcastId, createdAt])
  @@index([userId, createdAt])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  orderId   String?
  productId String
  delta     Int
  reason    String
  createdAt DateTime @default(now())

  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([orderId])
}
