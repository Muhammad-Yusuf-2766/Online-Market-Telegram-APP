# Copy values into the Railway **api** service → Variables.
# Use Railway references where noted (Insert variable → service → Postgres).

NODE_ENV=production

# Required — link to Railway PostgreSQL (service name may differ)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# JWT (generate strong random strings in production)
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES_IN=1d

# Telegram (server-only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_INIT_DATA_MAX_AGE_SEC=86400
TELEGRAM_WEB_APP_URL=https://your-web-service.up.railway.app
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEB_APP_SHORT_NAME=

# CORS — comma-separated public origins of web + admin (+ local dev if needed)
CORS_ORIGINS=https://your-web-service.up.railway.app,https://your-admin-service.up.railway.app

# MinIO / S3-compatible storage (use Railway MinIO template, or external S3/R2)
MINIO_ENDPOINT=https://your-minio-host
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=parfumbox
MINIO_PUBLIC_URL=https://your-public-bucket-url
MINIO_PRESIGN_EXPIRES_SEC=3600
