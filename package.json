{
	"name": "ansor-market",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@9.15.9",
	"scripts": {
		"prepare": "husky",
		"version": "node scripts/print-version.mjs",
		"docker:up": "docker compose up --build",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f",
		"dev:web": "pnpm --filter web dev",
		"dev:web:tunnel": "concurrently -k -n web,ngrok -c cyan,magenta \"pnpm --filter web dev\" \"ngrok http 5173\"",
		"ngrok": "ngrok http http://localhost:5173",
		"dev:admin": "pnpm --filter admin dev",
		"dev:api": "pnpm --filter api start:dev",
		"build": "pnpm -r run build",
		"lint": "pnpm -r run lint",
		"test": "jest --runInBand",
		"test:api": "pnpm --filter api test",
		"test:api:e2e": "pnpm --filter api test:e2e",
		"test:api:cov": "pnpm --filter api test:cov",
		"docker:test-db": "docker compose -f docker/docker-compose.test.yml up -d",
		"docker:test-db:down": "docker compose -f docker/docker-compose.test.yml down"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/jest": "29",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"jest": "29",
		"ngrok": "5.0.0-beta.2",
		"ts-jest": "29"
	}
}
